{
  "title": "DLW — SLO / Error Budget",
  "uid": "dlw-slo",
  "tags": ["dlw", "slo"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Availability — 30d (target 99.9%)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "avg_over_time(dlw:api_availability:ratio_rate5m[30d]) * 100" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Task Completion Rate — 7d (target 99%)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "dlw:task_completion:ratio_rate7d * 100" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 98 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "API Burn Rate (1h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "dlw:api_availability:burn_rate_1h" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Budget Remaining (30d)",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "100 * (1 - (1 - avg_over_time(dlw:api_availability:ratio_rate5m[30d])) / (1 - 0.999))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Availability over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "targets": [
        { "expr": "dlw:api_availability:ratio_rate5m * 100", "legendFormat": "5m availability" },
        { "expr": "99.9", "legendFormat": "SLO target" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 99, "max": 100 }
      }
    },
    {
      "id": 6,
      "title": "Burn rate windows (multi-burn-rate alerting basis)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "targets": [
        { "expr": "dlw:api_availability:burn_rate_1h", "legendFormat": "1h burn rate" },
        { "expr": "dlw:api_availability:burn_rate_6h", "legendFormat": "6h burn rate" },
        { "expr": "14.4", "legendFormat": "Page threshold (1h × 14.4)" }
      ]
    }
  ]
}
