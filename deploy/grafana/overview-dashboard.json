{
  "title": "DLW — Overview",
  "uid": "dlw-overview",
  "tags": ["dlw"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "query": "label_values(dlw_tasks_active_count, tenant_id)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(dlw_tasks_active_count{tenant_id=~\"$tenant\"})",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Tasks completed (7d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(dlw_tasks_completed_total{status=\"completed\"}[7d]))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tasks failed (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(dlw_tasks_completed_total{status=\"failed\"}[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Healthy executors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(dlw_executor_health_score >= 70)",
          "legendFormat": "healthy"
        }
      ]
    },
    {
      "id": 5,
      "title": "API SLO (30d)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "avg_over_time(dlw:api_availability:ratio_rate5m[30d]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Bytes downloaded / sec (cluster)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (source_id) (rate(dlw_chunk_download_bytes_total[5m]))",
          "legendFormat": "{{source_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 7,
      "title": "Source health",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "dlw:source_health:by_id",
          "legendFormat": "{{source_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Task duration P50/P95/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(dlw_task_duration_seconds_bucket[1h])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(dlw_task_duration_seconds_bucket[1h])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(dlw_task_duration_seconds_bucket[1h])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Subtask retries by reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (reason) (rate(dlw_subtask_retries_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Executor health score (top 20)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "topk(20, dlw_executor_health_score)",
          "format": "table"
        }
      ]
    }
  ]
}
